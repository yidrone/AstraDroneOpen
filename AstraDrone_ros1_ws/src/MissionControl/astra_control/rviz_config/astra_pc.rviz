Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Axes1
        - /Axes1/odom1
        - /Axes1/Axes1
        - /Planning1
        - /Planning1/bspline_traj1
        - /Mapping1
        - /Mapping1/local_map1
        - /Mapping1/local_map1/Autocompute Value Bounds1
      Splitter Ratio: 0.4324324429035187
    Tree Height: 862
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
      - /ThirdPersonFollower1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: current_point
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
