<?xml version="1.0"?>
<launch> 
    <arg name="rviz" default="false" />
    <rosparam param="debug">true</rosparam>  
    <rosparam file="$(find astra_control)/config/astra_real.yaml" />
    
    <node pkg="astra_control" type="astra_return_node" name="astra_return" output="screen">
        <remap from="/detect/waypoint_mark" to="/detect/waypoint_mark"/>
        <remap from="/detect/land_mark" to="/detect/land_mark"/>
    </node>

    <include file="$(find plan_manage)/launch/fast_planner_real.launch" />
<!-- 
    <node pkg="astra_auto_land" type="astra_static_land" name="astra_static_land" output="screen">
        <param name="search_altitude" value="8.0" />
        <param name="horizontal_acceptance_radius" value="0.05" />
        <param name="yaw_acceptance_threshold" value="0.02" />
        <param name="target_timeout" value="1.5" />
        <param name="search_timeout" value="200.0" />
        <param name="base_descent_z" value="0.5" />
        <param name="max_descent_z" value="1.0" />
        <param name="max_yaw_speed" value="0.4" />
        <param name="lock_motor_z_threshold" value="0.05" />
        <param name="z_two_stage" value="1.5" />
        <param name="z_three_stage" value="30.0" />
        <param name="need_ground_check" value="true" />  
        <param name="ground_check_interval" value="0.05" />
        <param name="ground_check_duration" value="3.0" />

        
        <remap from="/apriltag/Point/pixel" to="/detect/pixel_coord"/> 
    </node> -->

    <group if="$(arg rviz)">
	<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find astra_control)/rviz_config/astra_nano.rviz" />
	</group>
</launch>