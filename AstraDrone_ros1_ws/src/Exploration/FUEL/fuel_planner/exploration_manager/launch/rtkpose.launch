<launch>


  <!-- 设置全局 use_sim_time 参数 -->
  <!-- for rosbag play xx clock -->
  <!-- <param name="/use_sim_time" value="true" /> -->

  <node pkg="tf" type="static_transform_publisher" name="tf_base2camera" 
      args="0.0 0 0 -1.57 0 -1.57 body camera_link 40" />
  <node pkg="tf" type="static_transform_publisher" name="tf_mapworld" args="0 0 0 0 0 0 world map 100" />


  <!-- 从tf转到odom -->
  <!-- output /mavros/camera_pose --> 
  <node name="tf_to_odometry_node" pkg="topic_tf_tran" type="tf2topic" output="screen">
      <!-- 传入参数 -->
      <param name="map_frame_id_" value="map" />
      <param name="base_link_frame_id_" value="camera_link" />
      <!-- 输出参数 -->
      <param name="odom_pub_topic" value="/mavros/camera_pose" />
  </node>

</launch>
