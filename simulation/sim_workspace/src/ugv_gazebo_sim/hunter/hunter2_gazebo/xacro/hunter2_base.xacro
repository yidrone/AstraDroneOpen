          filename="package://two_degree_platform/meshes/plat_link.STL" />
      </geometry>
    </collision>
    <dynamic damping="0.7" friction="0.5"/>
  </link>
  <joint
    name="platform_2_joint"
    type="fixed">
    <origin
      xyz="0 -0.0278 0.057"
      rpy="0 0 -1.5708" />
    <parent
      link="platform_1_link" />
    <child
      link="platform_2_link" />
    <axis
      xyz="0 0 0" />
  </joint>
















